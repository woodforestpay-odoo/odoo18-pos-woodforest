<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="payment_token_wizard_form_view" model="ir.ui.view">
        <field name="name">payment.token.wizard.form</field>
        <field name="model">payment.token.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate a Payment Token" class="payrillium-token-form">
                <group col="2" colspan="2">
                    <field name="partner_id" readonly="1"/>
                    <field name="account_type" required="1"/>
                    <field name="amount" invisible="1"/>

                </group>
                <group col="2" colspan="2" invisible="account_type == 'card'">
                    <field name="account_number" placeholder="123456789"/>
                    <field name="routing_number" placeholder="987654321"/>
                </group>

               
                <group invisible="account_type != 'card'">
                    <field name="card_number" />
                    <label for="expiration_month" string="Expiration Date / CVC"/>
                    <div class="o_row">
                        <field name="expiration_month" nolabel="1" placeholder="MM" class="oe_inline"/>
                        <span class="oe_inline">/</span>
                        <field name="expiration_year" nolabel="1" placeholder="YY" class="oe_inline"/>
                        <field name="security_code" nolabel="1" placeholder="CVC" class="oe_inline cvc-input"/>
                    </div>
                </group>



                <group col="2" colspan="2">
                    <field name="billing_address_required" readonly="1"/>
                </group>
                <separator string="Billing Address"/>
                <group col="2" colspan="2">
                    <field name="first_name" placeholder="First Name" 
                           readonly="not billing_address_required"/>
                    <field name="last_name" placeholder="Last Name" readonly="not billing_address_required"/>
                    <field name="email" widget="email" placeholder="Email" readonly="not billing_address_required"/>
                    <field name="phone" widget="phone" placeholder="Phone" readonly="not billing_address_required"/>
                </group>

                <group col="2" colspan="2">
                    <field name="country" readonly="not billing_address_required"  options="{'no_open': True}"/>
                    <field name="address_line_1" placeholder="Street address or P.O. Box" readonly="not billing_address_required"/>
                    <field name="address_line_2" placeholder="Apt, suite, unit number, floor, etc. (optional)" readonly="not billing_address_required"/>
                </group>

                <group col="3" colspan="3">
                    <field name="city" placeholder="City" readonly="not billing_address_required"/>
                    <field name="state" placeholder="e.g. IL" readonly="not billing_address_required"/>
                    <field name="zip_code" placeholder="ZIP" readonly="not billing_address_required"/>
                </group>

                <footer>
                    <button name="action_generate_token" 
                            string="Submit" 
                            type="object" 
                            
                            class="btn-primary"/>
                    <button string="Reset Form" type="object" name="action_reset_form" class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
