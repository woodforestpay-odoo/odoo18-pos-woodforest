<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- list view -->
    <record id="view_payrillium_payment_link_list" model="ir.ui.view">
        <field name="name">payrillium.payment.link.list</field>
        <field name="model">payrillium.payment.link</field>
        <field name="arch" type="xml">
            <list js_class="custom_list_view" create="0" delete="0" export_xlsx="0" decoration-success="status == 'active'"
                    decoration-info="status == 'paid'"
                    decoration-warning="status == 'expired'"
                    decoration-danger="status == 'inactive'">
                <field name="payment_link_id" />
                <field name="invoice_id"/>
                <field name="status"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="created_at"/>
                <field name="link_url" invisible="1"/>
                <button name="open_link_url" type="object" string="Open Payment Link" class="btn-primary"/>

            </list>
        </field>
    </record>
    <!-- Form view -->
    <record id="view_payrillium_payment_link_form" model="ir.ui.view">
        <field name="name">payrillium.payment.link.form</field>
        <field name="model">payrillium.payment.link</field>
        <field name="arch" type="xml">
            <form create="0" delete="0">
                <group>
                    <field name="payment_link_id"  readonly="1"/>
                    <field name="status"/>
                    <field name="amount"  readonly="1"/>
                    <field name="link_as_html" widget="html" readonly="1"/>
                    <field name="currency_id"  readonly="1"/>
                    <field name="created_at"  readonly="1"/>
                    <field name="expiration_date"  readonly="1"/>

                </group>
            </form>
        </field>
    </record>
    <record id="action_payrillium_payment_links" model="ir.actions.act_window">
        <field name="name">Pay by Links</field>
        <field name="res_model">payrillium.payment.link</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>


