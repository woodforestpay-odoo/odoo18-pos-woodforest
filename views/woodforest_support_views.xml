<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════════════
         SERVER LOGS — List view of payrillium.log (native Odoo export)
         ══════════════════════════════════════════════════════════════ -->
    <record id="view_payrillium_log_list" model="ir.ui.view">
        <field name="name">payrillium.log.list</field>
        <field name="model">payrillium.log</field>
        <field name="arch" type="xml">
            <list string="Server Logs"
                  create="0" delete="0" duplicate="0"
                  export_xlsx="1">
                <field name="timestamp" widget="datetime" optional="show"/>
                <field name="execution_id" optional="show"/>
                <field name="log_type" optional="show"/>
                <field name="endpoint" optional="show"/>
                <field name="success" optional="show"/>
                <field name="error_message" optional="show"/>
                <field name="request_payload" optional="hide"/>
                <field name="response_payload" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Search view with date range filter -->
    <record id="view_payrillium_log_search" model="ir.ui.view">
        <field name="name">payrillium.log.search</field>
        <field name="model">payrillium.log</field>
        <field name="arch" type="xml">
            <search string="Search Logs">
                <field name="execution_id" string="Execution ID"/>
                <field name="endpoint" string="Endpoint"/>
                <field name="error_message" string="Error"/>
                <filter string="Today" name="today"
                        domain="[('timestamp','&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0))),
                                 ('timestamp','&lt;=', datetime.datetime.combine(context_today(), datetime.time(23,59,59)))]"/>
                <filter string="Last 7 days" name="last_7_days"
                        domain="[('timestamp','&gt;=',(datetime.date.today()-datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter string="Last 30 days" name="last_30_days"
                        domain="[('timestamp','&gt;=',(datetime.date.today()-datetime.timedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Errors only" name="errors_only"
                        domain="[('success','=',False)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_log_type" context="{'group_by':'log_type'}"/>
                    <filter string="Date" name="group_date" context="{'group_by':'timestamp:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_payrillium_server_logs" model="ir.actions.act_window">
        <field name="name">Server Logs</field>
        <field name="res_model">payrillium.log</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_payrillium_log_search"/>
        <field name="context">{'search_default_last_7_days': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No logs found</p>
            <p>Use the filters above to select a date range, then export via Actions → Export.</p>
        </field>
    </record>


    <!-- ══════════════════════════════════════════════════════════════
         SUPPORT CLIENT ACTION — OWL landing page
         ══════════════════════════════════════════════════════════════ -->
    <record id="action_payrillium_support" model="ir.actions.client">
        <field name="name">Support</field>
        <field name="tag">payrillium_support_page</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         FAQ CLIENT ACTION — OWL landing page
         ══════════════════════════════════════════════════════════════ -->
    <record id="action_payrillium_faq" model="ir.actions.client">
        <field name="name">Terminal FAQ</field>
        <field name="tag">pos_woodforest.FaqPage</field>
    </record>

    <!-- Menu items -->
    <menuitem id="menu_payrillium_faq"
              name="FAQ"
              parent="menu_payrillium_root"
              action="action_payrillium_faq"
              sequence="98"/>

    <!-- Menu items -->
    <menuitem id="menu_payrillium_support"
              name="Support"
              parent="menu_payrillium_root"
              action="action_payrillium_support"
              sequence="99"/>
</odoo>
