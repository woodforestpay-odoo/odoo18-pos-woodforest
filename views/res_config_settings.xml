<odoo> 
    <record id="res_config_settings_view_form_payrillium" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.payrillium</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_payment_terminals_section']" position="inside">
                <setting id="payrillium_terminal_setting">
                    <field name="enable_payrillium_terminal" readonly="1"/>
                    <field name="has_custom_payment" readonly="1" invisible="1"/>
                    <div class="text-muted" invisible="has_custom_payment">
                        To use these terminals, you must add the 'Woodforest' payment method to your POS session.
                    </div>
                    
                    <div class="content-group mt16">
                        <field name="dummy_terminal_label" readonly="1" class="text-muted"/>
                        <field name="terminal_id"
                               options="{'no_create': True}"
                               string="Available Terminals"
                               domain="['|','|', ('serial','=','NONE'), ('pos_config_id','=', False), ('pos_config_id','=', pos_config_id)]"
                               readonly="not has_custom_payment"
                               invisible="not has_custom_payment"
                               />
                    </div>

                    <div class="mt16">
                        <field name="pos_iface_splitbill" readonly="not has_custom_payment or pos_has_active_session"/>
                        <label for="pos_iface_splitbill" string="Allow Bill Splitting"/>
                        <div class="text-muted">
                             Split total or order lines (Retail Mode)
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>

