<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ─── Assign Terminal to POS Wizard ─────────────────────────────── -->
        <record id="view_payrillium_assign_wizard_form" model="ir.ui.view">
            <field name="name">payrillium.assign.wizard.form</field>
            <field name="model">payrillium.assign.wizard</field>
            <field name="arch" type="xml">
                <form string="Assign Terminal to POS">
                    <sheet>
                        <group>
                            <field name="terminal_id" invisible="1"/>
                            <field name="available_pos_ids" invisible="1"/>
                            <field name="terminal_name" string="Terminal"/>
                            <field name="current_pos_config_id" string="Currently Assigned To"/>
                            <field name="current_session_status" string="Session State" widget="badge"
                                   decoration-danger="current_session_status == 'busy'"
                                   decoration-success="current_session_status == 'available'"
                                   decoration-muted="current_session_status == 'none'"/>
                            <field name="new_pos_config_id"
                                   string="Assign To POS"
                                   options="{'no_open': True, 'no_create': True, 'no_quick_create': True}"
                                   placeholder="Select a closed POS session..."/>
                        </group>
                        <div class="text-muted mt-2 small">
                            <i class="fa fa-info-circle me-1"></i>
                            Only POS sessions with no active (open) session are shown.
                            To leave this terminal unassigned, leave the field empty.
                        </div>
                    </sheet>
                    <footer>
                        <button string="Confirm Assignment" type="object" name="action_confirm" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- ─── Action to open wizard ──────────────────────────────────────── -->
        <record id="action_payrillium_assign_wizard" model="ir.actions.act_window">
            <field name="name">Assign Terminal to POS</field>
            <field name="res_model">payrillium.assign.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
