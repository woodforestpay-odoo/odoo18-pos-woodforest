<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_payment_transaction_list_inherit_duplicate" model="ir.ui.view">
      <field name="name">payment.transaction.list.inherit.duplicate</field>
      <field name="model">payment.transaction</field>
      <field name="inherit_id" ref="payment.payment_transaction_list"/>
      <field name="arch" type="xml">
          <xpath expr="//list/field[@name='company_id']" position="after">
             <field name="duplicate_icon" string="" readonly="1"
                invisible="duplicate_icon == ''"
                options="{'no_open': True}" />
          </xpath>
      </field>
  </record>
</odoo>


